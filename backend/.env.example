LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=

# Optional OpenAI-compatible fallback provider.
# Set LLM_PROVIDER=openai-compatible and fill these values to call Typhoon,
# OpenAI, OpenRouter, LM Studio, Ollama's OpenAI-compatible endpoint, or another
# compatible router instead of Gemini.
LLM_API_KEY=
LLM_BASE_URL=https://api.opentyphoon.ai/v1
OPENAI_COMPATIBLE_MODEL=typhoon-v2.1-12b-instruct
