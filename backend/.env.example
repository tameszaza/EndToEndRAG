LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=

# Embeddings for retrieval. Use Gemini's free embedding model when the Gemini
# key is configured. Set EMBEDDING_PROVIDER=local for offline deterministic
# hashing embeddings.
EMBEDDING_PROVIDER=gemini
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIMENSIONS=768

# Optional OpenAI-compatible fallback provider.
# Set LLM_PROVIDER=openai-compatible and fill these values to call Typhoon,
# OpenAI, OpenRouter, LM Studio, Ollama's OpenAI-compatible endpoint, or another
# compatible router instead of Gemini.
LLM_API_KEY=
LLM_BASE_URL=https://api.opentyphoon.ai/v1
OPENAI_COMPATIBLE_MODEL=typhoon-v2.1-12b-instruct
